# Required: main upstream data service.
MINECRAFT_SERVER_URL=http://localhost:8080

# Optional: separate buildings upstream. Leave empty to use MINECRAFT_SERVER_URL.
BUILDINGS_SERVER_URL=

# Optional: Minecraft status fallback used when /api/players upstream is unavailable.
MINECRAFT_SERVER_ADDRESS=mcmik.top
MINECRAFT_SERVER_PORT=25565

# Optional: comma-separated browser origins allowed to read this Worker.
ALLOWED_ORIGINS=http://localhost:3000,https://mcmik.top

# Required: HMAC timestamp secret for MINECRAFT_SERVER_URL.
TOTP_SECRET=

# Optional: separate buildings HMAC secret. Leave empty to use TOTP_SECRET.
BUILDINGS_TOTP_SECRET=
